{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LiTongShuo-edu/resume-evidence-builder/blob/main/references/evidence-ledger.schema.json",
  "title": "Resume Evidence Ledger",
  "description": "Structured claims and verification evidence for a job-tailored resume.",
  "type": "object",
  "required": [
    "schema_version",
    "target_role",
    "job_requirements",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "target_role": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "public_repository": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "job_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "project": {
      "type": "object",
      "required": [
        "name",
        "public_repository"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "public_repository": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "requirement": {
      "type": "object",
      "required": [
        "id",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^REQ-[A-Z0-9-]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "kind",
        "label",
        "url",
        "supports"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "repository",
            "source",
            "test_record",
            "document",
            "artifact"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "supports": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": [
        "method",
        "result",
        "verified_on"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "verified_on": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": [
        "id",
        "statement",
        "status",
        "resume_ready",
        "requirement_ids",
        "evidence",
        "source_disclosure"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CLM-[A-Z0-9-]+$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "partially_verified",
            "unverified",
            "excluded"
          ]
        },
        "resume_ready": {
          "type": "boolean"
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "source_disclosure": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
